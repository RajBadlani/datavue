// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String      @id @default(uuid())
  name            String      @default("")
  email           String      @unique
  emailVerified   Boolean     @default(false)
  image           String?
  passwordHash    String?
  llmProvider     LLMProvider @default(ANTHROPIC)
  encryptedApiKey String?
  onboardingComplete Boolean  @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  sessions       Session[]
  accounts       Account[]
  connections    Connection[]
  conversations  Conversation[]
  auditLogs      AuditLog[]
  insights       Insight[]
  monitoredMetrics MonitoredMetric[]
  dashboardPages DashboardPage[]
  dashboardWidgets DashboardWidget[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

enum LLMProvider {
  ANTHROPIC
  OPENAI
  OLLAMA
}

model Connection {
  id                   String     @id @default(uuid())
  userId               String
  label                String
  dbType               DBType
  encryptedCredentials String
  syncStatus           SyncStatus @default(PENDING)
  lastSyncedAt         DateTime?
  piiColumns           String[]   @default([])
  isArchived           Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  schemaMetadata SchemaMetadata[]

  conversations  Conversation[]
  auditLogs      AuditLog[]
  insights       Insight[]
  monitoredMetrics MonitoredMetric[]
  dashboardWidgets DashboardWidget[]

  @@index([userId])
  @@map("connections")
}

enum DBType {
  POSTGRES
  MYSQL
  MONGODB
  SQLITE
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
}

model SchemaMetadata {
  id           String   @id @default(uuid())
  connectionId String
  tableName    String
  schemaName   String   @default("public")
  columns      Json
  primaryKeys  String[] @default([])
  foreignKeys  Json     @default("[]")
  indexes      Json     @default("[]")
  rowEstimate  BigInt   @default(0)
  syncedAt     DateTime @default(now())

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, tableName, schemaName])
  @@index([connectionId])
  @@map("schema_metadata")
}

model Conversation {
  id           String     @id @default(uuid())
  connectionId String
  userId       String
  messages     Json       @default("[]")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([connectionId, userId])
  @@index([connectionId])
  @@index([userId])
  @@map("conversations")
}

model AuditLog {
  id             String      @id @default(uuid())
  userId         String
  connectionId   String
  nlQuery        String
  sqlAttempts    Json        @default("[]")
  finalSql       String?
  executionMs    Int?
  rowCount       Int?
  maskedColumns  String[]    @default([])
  chartType      String?
  status         QueryStatus
  errorMessage   String?
  createdAt      DateTime    @default(now())

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection     Connection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("audit_logs")
}

enum QueryStatus {
  SUCCESS
  FAILED
  BLOCKED
  TIMEOUT
}

model Insight {
  id              String          @id @default(uuid())
  userId          String
  connectionId    String
  metricName      String
  insightText     String
  severity        InsightSeverity
  deltaPercent    Float
  currentValue    Float
  previousValue   Float
  comparisonType  ComparisonType
  status          InsightStatus   @default(ACTIVE)
  snoozedUntil    DateTime?
  createdAt       DateTime        @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection      Connection      @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([connectionId])
  @@index([status])
  @@index([createdAt])
  @@map("insights")
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ComparisonType {
  DAY_OVER_DAY
  WEEK_OVER_WEEK
  ROLLING_AVERAGE
}

enum InsightStatus {
  ACTIVE
  DISMISSED
  SNOOZED
}

model MonitoredMetric {
  id               String         @id @default(uuid())
  userId           String
  connectionId     String
  name             String
  description      String?
  queryTemplate    String
  comparisonType   ComparisonType
  thresholdPercent Float          @default(15.0)
  isTemplate       Boolean        @default(false)
  isActive         Boolean        @default(true)
  notifyEmail      Boolean        @default(false)
  lastRunAt        DateTime?
  lastRunStatus    MetricRunStatus?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection       Connection     @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([connectionId])
  @@index([isActive])
  @@map("monitored_metrics")
}

enum MetricRunStatus {
  SUCCESS
  FAILED
  NO_ANOMALY
}

model DashboardPage {
  id          String            @id @default(uuid())
  userId      String
  name        String
  description String?
  isDefault   Boolean           @default(false)
  shareToken  String?           @unique
  isShared    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets     DashboardWidget[]

  @@index([userId])
  @@index([shareToken])
  @@map("dashboard_pages")
}

model DashboardWidget {
  id              String          @id @default(uuid())
  userId          String
  connectionId    String
  dashboardPageId String
  title           String
  sql             String
  chartConfig     Json
  widgetType      WidgetType
  refreshSchedule RefreshSchedule @default(MANUAL)
  lastRefreshedAt DateTime?
  cachedResult    Json?
  cachedRowCount  Int?
  displayOrder    Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection      Connection      @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  dashboardPage   DashboardPage   @relation(fields: [dashboardPageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([connectionId])
  @@index([dashboardPageId])
  @@map("dashboard_widgets")
}

enum WidgetType {
  CHART
  METRIC_CARD
  DATA_TABLE
}

enum RefreshSchedule {
  MANUAL
  HOURLY
  DAILY
}
